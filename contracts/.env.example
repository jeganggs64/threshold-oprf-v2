# Contract deployment configuration
# Copy to .env and fill in values: cp .env.example .env

# Deployer wallet private key (hex, without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# RPC URL for the target chain
# Base Mainnet: https://mainnet.base.org
# Base Sepolia (testnet): https://sepolia.base.org
RPC_URL=https://sepolia.base.org

# Etherscan/Basescan API key for contract verification (optional)
ETHERSCAN_API_KEY=
