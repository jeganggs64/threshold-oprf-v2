pragma solidity ^0.8.20;

import "forge-std/Script.sol";
import "../src/TOPRFRegistry.sol";

/// @notice Deploys TOPRFRegistry with DKG ceremony data.
///         The constructor args are read from a JSON file (dkg-data.json)
///         generated by the DKG CLI after the ceremony.
///
/// Usage:
///   1. Run DKG ceremony → produces dkg-data.json
///   2. Place dkg-data.json in contracts/
///   3. bash deploy.sh
contract DeployScript is Script {
    function run() external {
        uint256 deployerKey = vm.envUint("DEPLOYER_PRIVATE_KEY");

        // Read DKG data from JSON file
        string memory json = vm.readFile("dkg-data.json");

        bytes32 groupPublicKey = vm.parseJsonBytes32(json, ".groupPublicKey");
        string memory sourceRepo = vm.parseJsonString(json, ".sourceRepo");
        uint8 threshold = uint8(vm.parseJsonUint(json, ".threshold"));

        // Parse node records
        uint256 nodeCount = vm.parseJsonUint(json, ".nodeCount");
        TOPRFRegistry.NodeRecord[] memory nodes = new TOPRFRegistry.NodeRecord[](nodeCount);

        for (uint256 i = 0; i < nodeCount; i++) {
            string memory prefix = string.concat(".nodes[", vm.toString(i), "]");
            nodes[i] = TOPRFRegistry.NodeRecord({
                nodeId: uint8(vm.parseJsonUint(json, string.concat(prefix, ".nodeId"))),
                dkgCommitment: vm.parseJsonBytes(json, string.concat(prefix, ".dkgCommitment")),
                attestationReport: vm.parseJsonBytes(json, string.concat(prefix, ".attestationReport")),
                certChain: vm.parseJsonBytes(json, string.concat(prefix, ".certChain")),
                verificationShare: vm.parseJsonBytes32(json, string.concat(prefix, ".verificationShare"))
            });
        }

        vm.startBroadcast(deployerKey);
        TOPRFRegistry registry = new TOPRFRegistry(
            groupPublicKey,
            sourceRepo,
            threshold,
            nodes
        );
        vm.stopBroadcast();

        console.log("TOPRFRegistry deployed at:", address(registry));
        console.log("Group public key:", vm.toString(groupPublicKey));
        console.log("Threshold:", threshold);
        console.log("Nodes:", nodeCount);
    }
}
