# =============================================================================
# Deployment configuration for threshold OPRF system (all-AWS).
#
# Prerequisites:
#   - AWS TEE VMs (AMD SEV-SNP) provisioned
#   - IAM instance profiles attached to each VM
#   - SSH access to all VMs
#   - aws CLI authenticated locally
#   - jq installed locally
#
# Node configuration (regions, IPs, keys, S3 buckets) lives in nodes.json.
# Copy nodes.json.example → nodes.json, then fill in node details.
# Run `./deploy.sh auto-config` after provisioning to populate IPs/SGs/VPCs.
# =============================================================================

# ─── AWS Account ────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=                       # [auto] from aws sts get-caller-identity

# ─── Provisioning ──────────────────────────────────────────────────────────
INSTANCE_TYPE=c6a.large               # [manual] VM instance type for nodes
# IAM roles are created per-node automatically by provision.sh (toprf-node-<id>-role)

# ─── Node image (built by CI, pulled from ghcr.io) ─────────────────────────
# NODE_IMAGE=ghcr.io/<your-username>/toprf-node:latest  # [manual] override if needed

# ─── Node shares ───────────────────────────────────────────────────────────
NODE_SHARES_DIR=../ceremony/node-shares  # [manual]

# ─── CloudWatch / Rotation ─────────────────────────────────────────────────
SNS_ALERT_TOPIC=toprf-node-alerts     # [manual] SNS topic for unhealthy-node alarms
ROTATION_LAMBDA=toprf-rotation        # [manual] Lambda function for automated rotation

# ─── SEV-SNP Attestation ──────────────────────────────────────────────────
EXPECTED_MEASUREMENT=                 # [auto] set by `./deploy.sh measure` — SEV-SNP launch measurement
AMD_ARK_FINGERPRINT=                  # [auto] set by `./deploy.sh measure` — SHA-256 of AMD ARK cert (DER)

# ─── API Server ─────────────────────────────────────────────────────────────
DOMAIN=                               # [manual] e.g. api.example.com
APPLE_TEAM_ID=                        # [manual] Apple Developer Team ID
APPLE_APP_ID=                         # [manual] e.g. TEAMID.com.example.app
SIGNING_KEY_ID=                       # [manual] KMS key alias for JWT signing
