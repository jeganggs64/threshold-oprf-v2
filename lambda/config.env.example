# OPRF Lambda deployment config
# Copy to config.env and fill in values, or run:
#   ./deploy/deploy.sh lambda-config
# to auto-populate fields marked [auto] from deployment state.
ACCOUNT_ID=                           # [auto] from AWS caller identity
API_ID=                               # [manual] OPRF API Gateway ID (oprf.ruonlabs.com)
LAMBDA_PREFIX=ruonid
REGION=eu-west-1                      # [auto] coordinator node region
ROLE_ARN=                             # [manual] Lambda execution role ARN

# Apple App Attest
APPLE_APP_ID=                         # [manual]
APPLE_TEAM_ID=                        # [manual]

# VPC config for evaluate Lambda (needs internal NLB access)
VPC_SUBNETS=                          # [auto] coordinator VPC subnets
VPC_SG=                               # [auto] coordinator node security group

# DynamoDB table names
NONCES_TABLE=ruonid-nonces
DEVICE_KEYS_TABLE=ruonid-device-keys

# Coordinator NLB URL
NLB_URL=                              # [auto] from privatelink-state.env
