# deploy-nodes.sh configuration
# Copy to deploy-nodes.env and fill in values

# Comma-separated AWS regions to deploy to (one node per region)
TOPRF_REGIONS="us-east-2,eu-central-1,ap-northeast-1"

# SSH key pair name (must exist in each region, or will be created)
TOPRF_KEY_NAME="toprf-v2-test"

# Path to SSH private key file
TOPRF_SSH_KEY="~/.ssh/toprf-v2-test.pem"

# Path to downloaded Nitro artifacts directory
# (must contain toprf-node-enclave.tar.gz and toprf-node)
TOPRF_IMAGE_DIR="/tmp/nitro-artifacts"

# Path to CLI binaries directory
# (must contain toprf-dkg-cli and toprf-reshare-cli)
TOPRF_CLI_DIR="/tmp/cli-binaries"

# Instance type (must support Nitro Enclaves, minimum 4 vCPUs)
TOPRF_INSTANCE_TYPE="c5a.xlarge"

# Node mode: "genesis" for initial DKG, "join" for resharing
TOPRF_MODE="genesis"

# Threshold parameters (only used in genesis mode)
TOPRF_THRESHOLD=2
TOPRF_TOTAL=3

# Set to "true" to launch enclaves in debug mode (zeros PCRs — testing only)
TOPRF_DEBUG="true"
