# run-dkg.sh configuration
# Copy to run-dkg.env and fill in values

# Comma-separated node URLs (output from deploy-nodes.sh)
TOPRF_NODE_URLS="http://1.2.3.4:3001,http://5.6.7.8:3001,http://9.10.11.12:3001"

# IP of the instance to run the DKG CLI from (usually the first node)
TOPRF_DKG_HOST="1.2.3.4"

# SSH key pair name (must match what deploy-nodes.sh used)
# Private key is at ~/.ssh/<name>.pem
TOPRF_KEY_NAME="toprf-v2"

# Path to contracts.tar.gz (downloaded from CI artifacts)
# Required for on-chain registry deployment
TOPRF_CONTRACTS_TAR="/tmp/toprf-deploy/contracts/contracts.tar.gz"

# Deployer wallet private key for on-chain registry (hex, no 0x prefix)
# Leave empty to skip contract deployment
DEPLOYER_PRIVATE_KEY=""

# RPC URL for contract deployment
RPC_URL="https://sepolia.base.org"
